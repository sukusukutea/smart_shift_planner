<% active_tab =
      case params[:tab]
      when "daily"
        "daily"
      when "month"
        "month"
      else
        "holiday"
      end %>

<div class="h-100 d-flex flex-column" style="background-color: #e6f0f0;">
  <!-- 切り替えボタン -->
  <div class="d-flex justify-content-around px-1 py-1 border-bottom">
    <button class="btn btn-outline-secondary btn-sm w-100 <%= active_tab == "holiday" ? "active" : "" %>"
            id="btn-holiday" onclick="showTab('holiday')">休日設定</button>
    <button class="btn btn-outline-secondary btn-sm w-100 <%= active_tab == "daily" ? "active" : "" %>"
            id="btn-daily" onclick="showTab('daily')">日別調整</button>
    <button class="btn btn-outline-secondary btn-sm w-100 <%= active_tab == "month" ? "active" : "" %>"
            id="btn-month" onclick="showTab('month')">月設定</button>
  </div>

  <!-- コンテンツ -->
  <div class="flex-grow-1 px-3 pt-3" id="tab-content-area">
    <div id="tab-holiday" style="<%= active_tab == "holiday" ? "" : "display:none;" %>">
      <%= render "shift_months/right_sidebar_holiday" %>
    </div>

    <div id="tab-daily" style="<%= active_tab == "daily" ? "" : "display: none;" %>">
      <%= render "shift_months/right_sidebar_daily" %>
    </div>

    <div id="tab-month" style="<%= active_tab == "month" ? "" : "display:none;" %>">
      <%= render "shift_months/right_sidebar_month" %>
    </div>
  </div>
</div>

<script>
  function showTab(tabName) {
    document.getElementById("tab-holiday").style.display = tabName === "holiday" ? "block" : "none";
    document.getElementById("tab-daily").style.display = tabName === "daily" ? "block" : "none";
    document.getElementById("tab-month").style.display = tabName === "month" ? "block" : "none";

    document.getElementById("btn-holiday").classList.toggle("active", tabName === "holiday");
    document.getElementById("btn-daily").classList.toggle("active", tabName === "daily");
    document.getElementById("btn-month").classList.toggle("active", tabName === "month");
  }
</script>

<script>
  document.addEventListener("turbo:load", () => {
    const toggle = document.getElementById("toggle-late");
    const box = document.getElementById("late-slots-box");
    if (!toggle || !box) return;
    const sync = () => { box.style.display = toggle.checked ? "block" : "none"; };
    toggle.addEventListener("change", sync);
    sync();
  });
</script>
